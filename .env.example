# Copy to .env for docker compose / local runs (never commit real tokens).

# Required: Hugging Face token with access to pyannote models.
HUGGINGFACE_TOKEN=hf_your_token_here

# Optional: protect job endpoints (POST/GET /jobs*, POST /admin/warmup)
# SERVICE_API_TOKEN=

# Service tuning (defaults match docker-compose.yml)
# SERVICE_HOST=0.0.0.0
# SERVICE_PORT=8080
# SERVICE_DATA_DIR=/data
# SERVICE_OUTPUT_DIR=/exports
# SERVICE_DB_PATH=/var/lib/transcription/jobs.db
# SERVICE_CACHE_ROOT=/cache
# SERVICE_MAX_QUEUED_JOBS=16
# SERVICE_JOB_TIMEOUT_SEC=14400

# Set to false for CPU-only hosts (not recommended for production throughput).
# SERVICE_REQUIRE_CUDA=true

# SERVICE_LOG_LEVEL=INFO
